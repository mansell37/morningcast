# Copy to .env and fill in. NEVER commit the real .env (it's gitignored).

# --- required: research providers ---
ANTHROPIC_API_KEY=
XAI_API_KEY=

# --- audio backend ---
# Options: stub | kokoro | dia2 | elevenlabs
# Start with "stub" to test the whole pipeline with zero accounts,
# then switch to "kokoro" (free) once you've pip-installed it.
MC_AUDIO_BACKEND=stub
ELEVENLABS_API_KEY=

# --- optional model overrides ---
# MC_CLAUDE_MODEL=claude-opus-4-7
# MC_GROK_MODEL=grok-4.3

# --- research backend ---
# "grok+claude" (default): Grok live web search → Claude synthesis
# "claude":               Claude alone (no live web; use if xAI is unavailable)
# MC_RESEARCH_BACKEND=grok+claude

# --- episode shape ---
MC_TARGET_MINUTES=6
MC_HOST_A=Alex
MC_HOST_B=Sam

# --- local GPU worker (build-on-PC / Dia2) ---
# Shared secret the PC worker presents to the server. Set the SAME value here
# (on the server) and in the worker's environment on your PC. Leave empty to
# disable PC builds. Generate one with:
#   python -c "import secrets; print(secrets.token_urlsafe(32))"
MC_WORKER_TOKEN=
# How often the PC worker polls for new jobs (seconds). Worker-side only.
# MC_WORKER_POLL_SECONDS=10

# --- feed metadata ---
MC_FEED_TITLE=CoffeeCast
MC_FEED_AUTHOR=Matthew
MC_FEED_DESCRIPTION=Concise, AI-curated morning learning podcasts.
# Set this to your public URL when hosting (e.g. on Railway):
MC_BASE_URL=http://localhost:8000
