# Copy to .env and fill in. NEVER commit the real .env (it's gitignored).

# --- required: research providers ---
ANTHROPIC_API_KEY=
XAI_API_KEY=

# --- audio backend ---
# Options: stub | kokoro | dia2 | elevenlabs
# Start with "stub" to test the whole pipeline with zero accounts,
# then switch to "kokoro" (free) once you've pip-installed it.
MC_AUDIO_BACKEND=stub
ELEVENLABS_API_KEY=

# --- optional model overrides ---
# MC_CLAUDE_MODEL=claude-opus-4-7
# MC_GROK_MODEL=grok-4.3

# --- episode shape ---
MC_TARGET_MINUTES=6
MC_HOST_A=Alex
MC_HOST_B=Sam

# --- feed metadata ---
MC_FEED_TITLE=MorningCast
MC_FEED_AUTHOR=Matthew
MC_FEED_DESCRIPTION=Concise, AI-curated morning learning podcasts.
# Set this to your public URL when hosting (e.g. on Railway):
MC_BASE_URL=http://localhost:8000
